` : ''}

Identity Confidence: ${Math.round(context.v5_identity.identity_confidence * 100)}%

═══════════════════════════════════════════════

` : ''}${context.brand_voice ? `
PERSONALITY ANCHOR (Styrer al content-skrivning):
${(context.brand_voice as any).brand_essence || context.brand_voice.voice_style ? `🏷️ "${(context.brand_voice as any).brand_essence || context.brand_voice.voice_style}"` : ''}
${(context.brand_voice as any).brand_essence_elaboration ? `📌 ${(context.brand_voice as any).brand_essence_elaboration}` : ''}
${(context.brand_voice as any).communication_goal ? `🎯 Kommunikationsmål: ${(context.brand_voice as any).communication_goal}` : ''}
${(() => {
  const kw: string[] = (context.brand_voice as any).identity_keywords || [];
  return kw.length > 0 ? `🔑 Identitet: ${kw.join(' · ')}` : '';
})()}
${(() => {
  const ta = (context.brand_voice as any).target_audience;
  if (!ta) return '';
  const primary = typeof ta === 'object' ? ta.primary : ta;
  return primary ? `• Målgruppe: ${primary}` : '';
})()}

TONE-GUIDE:
${(() => {
  const tone = context.brand_voice.tone_of_voice;
  if (typeof tone === 'string' && tone) return tone;
  if (typeof tone === 'object' && tone !== null) {
    const t = tone as any;
    const parts: string[] = [];
    if (t.primary_tone) parts.push(`Primær: ${t.primary_tone}${t.attributes?.length ? ` (${t.attributes.join(', ')})` : ''}`);
    if (t.formality_level) parts.push(`Formalitet: ${t.formality_level}`);
    return parts.join(' · ') || 'Ikke angivet';
  }
  return 'Ikke angivet';
})()}
${(() => {
  const toneKw: string[] = (context.brand_voice as any).tone_model?.primary_keywords || context.brand_voice.tone_keywords || [];
  return toneKw.length > 0 ? `• Kernepersonlighed: ${toneKw.join(' · ')}` : '';
})()}
${(context.brand_voice as any).humor_level ? `• Humor: ${(context.brand_voice as any).humor_level}` : ''}
${((context.brand_voice as any).typical_openings || [])[0] ? `✅ Typisk åbning: "${((context.brand_voice as any).typical_openings || [])[0]}"` : ''}
${(context.brand_voice as any).voice_constraints ? `⚠️ Skriveprincip: ${(context.brand_voice as any).voice_constraints}` : ''}
${(() => {
  const plg = (context.brand_voice as any)?.post_length_guidelines;
  if (!plg || !Array.isArray(plg) || plg.length === 0) return '';
  const formatted = plg.map((g: any) => g.content_type && g.target_length ? `${g.content_type}: ${g.target_length} tegn` : null).filter(Boolean).join(', ');
  return formatted ? `📏 LÆNGDEKRAV: ${formatted}` : '';
})()}
${(() => {
  const avoidEx: string[] = (context.brand_voice as any).tone_model?.avoid_examples || [];
  return avoidEx.length > 0 ? `❌ Undgå fx: ${avoidEx.slice(0, 2).map((e: string) => `"${e}"`).join(' / ')}` : '';
})()}

DO'S — Hvad der virker for dette brand:
${(() => {
  const pillars = context.brand_voice.content_pillars;
  const phrases = (context.brand_voice as any).signature_phrases || [];
  const parts: string[] = [];
  if (Array.isArray(pillars) && pillars.length > 0) {
    pillars.slice(0, 5).forEach((p: any) => {
      if (p?.hook) parts.push(`→ ${p.hook}${p.usage ? `: ${p.usage}` : ''}`);
      else if (typeof p === 'string') parts.push(`→ ${p}`);
    });
  } else if (pillars && typeof pillars === 'object' && !Array.isArray(pillars)) {
    Object.entries(pillars as object).slice(0, 5).forEach(([k, v]) => parts.push(`→ ${k}: ${v}`));
  }
  if (phrases[0]) parts.push(`→ Signatur-sprogbrug (caption-ordvalg, ikke strategisk indhold): "${phrases[0]}"`);
  return parts.length > 0 ? parts.join('\n') : 'Ikke specificeret';
})()}
${(() => {
  const cs = (context.brand_voice as any)?.content_strategy;
  if (!cs) return '';
  const lines: string[] = [];
  const co = (context.brand_voice as any)?.core_offerings;
  if (co) {
    const coText = typeof co === 'string' ? co : Array.isArray(co) ? (co as string[]).join(', ') : null;
    if (coText) lines.push(`Kernetilbud: ${coText}`);
  }
  if (cs.footfall_signals?.length > 0) lines.push(`Fodfæste: ${(cs.footfall_signals as string[]).slice(0, 3).join(' · ')}`);
  if (cs.brand_anchors?.length > 0) lines.push(`Brand-ankre: ${(cs.brand_anchors as string[]).slice(0, 3).join(' · ')}`);
  if (cs.loyalty_hooks?.length > 0) lines.push(`Loyalitet: ${(cs.loyalty_hooks as string[]).slice(0, 3).join(' · ')}`);
  return lines.length > 0
    ? `\nPOST STRATEGI — brandets egne ankre (brug til at konkretisere vinkler):\n${lines.join('\n')}`
    : '';
})()}
` : ''}

${(context.location as any).matched_motivations?.length ? `
LOKATIONSTYPE & BESØGSMOTIVER:
- Primær lokalitetstype: ${(context.location as any).type}${(context.location as any).tourist_context ? ' (turistzone — mix af lokale og besøgende)' : ''}
${(() => {
  const cats = (context.location as any).location_categories as Array<{type: string; score: number}> | null;
  return cats && cats.length > 1 ? `- Aktive lokationstyper (≥60%): ${cats.map(c => `${c.type} (${c.score}%)`).join(', ')}` : '';
})()}
${(() => {
  const motivations = (context.location as any).matched_motivations as string[] | null;
  if (!motivations || motivations.length === 0) return '';
  return `- Besøgsmotiver (struktureret):\n${buildMotivationBlock(motivations)}`;
})()}
${(context.location as any).marketing_focus ? `- Markedsføringsfokus: ${(context.location as any).marketing_focus}` : ''}
- Strategisk konsekvens: Ugens content skal resonere med disse motivationstyper. Kombiner sæson (${context.season.current}) med de dominerende motiver — f.eks. hvis "familieudflug" er et motiv og det er sommer, lean ind i familieoplevelsesframing. Hvis "turist_oplevelse" er til stede, inkluder en distinkt lokal vinkel.
` : ''}

UGE KONTEKST:
${(() => {
  const wi = context.weather_interpretation;
  if (wi) {
    const lines: string[] = [];
    lines.push(`Nedbørsdage: ${wi.precipitation_days && wi.precipitation_days.length > 0 ? wi.precipitation_days.join(', ') : 'ingen'}`);
    lines.push(`Ugens vejrkarakter: ${wi.week_character ?? wi.operational_note}`);
    lines.push(`  Bias: ${wi.indoor_outdoor_bias} | Weekend: ${wi.weekend_usability}${ wi.strongest_opportunity_day ? ` | Bedste dag: ${wi.strongest_opportunity_day}` : ''}${ wi.strongest_constraint_day ? ` | Sværeste dag: ${wi.strongest_constraint_day}` : ''}`);
    if (wi.weather_is_newsworthy === false) {
      lines.push(`  Vejrnotat: Normalt vejr for måneden — brug IKKE vejret som strategisk signal eller narrativ vinkel denne uge.`);
    }
    return lines.join('\n');
  }
  // Fallback: raw weather summary if interpretation not available
  return `Vejr: ${context.weather.pattern}, ${context.weather.avg_temp}°C gennemsnit`;
})()}

VEJR DAG-TIL-DAG (tidsmæssige mønstre — brug blød formulering for dag 5-7):
${context.weather.days.map(d => {
  const date = new Date(d.date);
  const weekdayNames = ['Søn', 'Man', 'Tir', 'Ons', 'Tor', 'Fre', 'Lør'];
  const weekday = weekdayNames[date.getDay()];
  const hedge = d.reliability === 'cautious' ? ' ~usikker' : d.reliability === 'seasonal' ? ' ~sæson-estimat' : '';
  return `${weekday}: ${d.temp_min}-${d.temp_max}°C${d.precipitation_chance ? `, ${d.precipitation_chance}% regn` : ''}${d.wind_speed ? `, ${d.wind_speed}m/s vind` : ''}${hedge}`;
}).join(' | ')}

Sæson: ${context.season.current}
${(() => {
  const relevance = (context as any).economic_relevance_for_business as string | undefined;
  if (context.economic.payday_this_week && (relevance ?? 'medium') !== 'low') {
    const dayLabel = context.economic.payday_day_name ? ` (${context.economic.payday_day_name})` : '';
    const note = relevance === 'high'
      ? 'gæsterne er klar til at bruge penge på noget særligt'
      : 'gæsterne har lidt mere at bruge af end normalt';
    return `Timing: Lønningsuge${dayLabel} — ${note}`;
  }
  return `Timing: Uge ${context.economic.week_of_month}/4`;
})()}
${(() => {
  // CALENDAR SYSTEM: Add holiday-aware timing guidance
  const calendarContext = (context as any).calendar_context;
  console.log('[Phase 1] Calendar context:', JSON.stringify(calendarContext));
  const holidays = calendarContext?.holidays || [];
  console.log('[Phase 1] Holidays count:', holidays.length);
  
  if (holidays.length === 0) {
    console.log('[Phase 1] No holidays - skipping calendar guidance');
    return '';
  }
  
  console.log('[Phase 1] Building calendar guidance for', holidays.length, 'holidays');
  const lines: string[] = [];
  lines.push('\n🗓️ HELLIGDAGE DENNE UGE (fra kalender-system):');
  
  const dayNames = ['søndag', 'mandag', 'tirsdag', 'onsdag', 'torsdag', 'fredag', 'lørdag'];
  
  for (const holiday of holidays) {
    const date = new Date(holiday.date + 'T12:00:00Z');
    const dow = date.getUTCDay(); // 0=Sun, 1=Mon, ..., 6=Sat
    const dayName = dayNames[dow];
    
    lines.push(`  • ${dayName.charAt(0).toUpperCase() + dayName.slice(1)}: ${holiday.name_local} (${holiday.name})`);
    lines.push(`    Butikker: ${holiday.retail_impact === 'stores_closed' ? 'LUKKET ← caféer/restauranter får ekstra trafik' : holiday.retail_impact === 'reduced_hours' ? 'Reducerede timer' : 'Åbne normalt'}`);
    lines.push(`    Hospitality trafik: ${holiday.hospitality_traffic === 'surge' ? 'SURGE (højt besøg)' : holiday.hospitality_traffic === 'moderate_increase' ? 'Moderat stigning' : holiday.hospitality_traffic === 'reduced' ? 'Reduceret' : 'Normal'}`);
    if (holiday.typical_bridge_day) {
      lines.push(`    ⚠️ Klemmedag-potentiale: Hvis helligdagen er torsdag → mange tager fredag fri (forlænget weekend)`);
    }
  }
  
  // Add timing guidance for surge holidays
  const surgeHolidays = holidays.filter((h: any) => h.hospitality_traffic === 'surge');
  if (surgeHolidays.length > 0) {
    lines.push('');
    lines.push('⚡ TIMING STRATEGI FOR SURGE HELLIGDAGE:');
    lines.push('  Ved surge helligdage (butikker lukket + høj hospitality trafik):');
    lines.push('  • UNDGÅ mandage — brug i stedet onsdag/torsdag/fredag');
    lines.push('  • PRIORITER helligdagen selv + dagen før + klemmedagen (hvis relevant)');
    lines.push('  • timing_window eksempler for torsdag-helligdag:');
    lines.push('    - "Wed 14:00" (dagen før)');
    lines.push('    - "Thu 11:00" (selve helligdagen — PEAK DAY)');
    lines.push('    - "Fri 09:00" (klemmedag hvis relevant)');
    lines.push('    - "Sat 09:00" (weekend efter)');
    lines.push('  • REGEL: Slot D (retain_loyalty) må IKKE bruge "Mon-Wed" når der er torsdag surge-helligdag');
  }
  
  const result = lines.join('\n');
  console.log('[Phase 1] Calendar guidance length:', result.length, 'characters');
  return result;
})()}
Events: ${(context.events || []).length > 0 ? context.events.map((e: any) => {
  const weight = e.commercial_weight ?? e.weight ?? 2;
  // Holidays always get ★★★ regardless of commercial_weight — they define the week
  const star = e.type === 'holiday' ? ' ★★★' : weight >= 5 ? ' ★★★' : weight >= 4 ? ' ★★' : weight >= 3 ? ' ★' : '';
  // Tag events that fall outside this week so the AI treats them as lead-up context only
  const label = e.in_week === false ? `${e.name_dk}${star} (kommende uge)` : e.name_dk + star;
  return label;
}).join(', ') : 'Ingen'}${(context.events || []).some((e: any) => e.in_week !== false && (e.type === 'holiday' || (e.commercial_weight ?? e.weight ?? 2) >= 4)) ? `\n⚠️ HØJTPRIORITERET ANLEDNING (★★+): Helligdag eller kommercielt stærk begivenhed i DENNE uge. Planen SKAL afspejle dette i week_summary og mindst 1 post der direkte adresserer anledningen (reservation, særlig menu eller tilbud).
MÅ IKKE ignoreres til fordel for vejr eller lønning alene.` : ''}${(context.events || []).some((e: any) => e.in_week === false && (e.type === 'holiday' || (e.commercial_weight ?? e.weight ?? 2) >= 4)) ? `\nℹ️ KOMMENDE ANLEDNING (næste uge): Begivenhed vises som kontekst til lead-up planlægning. Den TILHØRER IKKE denne uges dage og må IKKE nævnes som om den sker i denne uge.` : ''}
${(() => {
  // Check for booking-critical occasions (Mors Dag, Fars Dag, Valentinsdag, etc.)
  const bookingCriticalEvents = (context.events || []).filter((e: any) => {
    const name = (e.name_dk || e.name || '').toLowerCase();
    const isBookingCritical = (
      name.includes('mors dag') ||
      name.includes('fars dag') ||
      name.includes('valentinsdag') ||
      name.includes('nytår') ||
      name.includes('jul') ||
      name.includes('påske') ||
      (e.commercial_weight ?? 0) >= 8  // Very high commercial weight = booking event
    );
    return isBookingCritical && e.in_week !== false; // Only in-week events
  });
  
  if (bookingCriticalEvents.length > 0) {
    const eventNames = bookingCriticalEvents.map((e: any) => e.name_dk || e.name).join(', ');
    return `\n\n🔴 BOOKING-KRITISK ANLEDNING (${eventNames}):\nDisse anledninger KRÆVER drive_footfall med EKSPLICIT BOOKING-FOKUS:\n  1. goal_mode: SKAL være "drive_footfall" (ikke build_brand eller retain_loyalty)\n  2. content_direction: SKAL eksplicit nævne "Book bord", "Reservér plads" eller lignende booking-opfordring\n  3. timing_window: Skal være 1-2 dage FØR selve dagen (torsdag-fredag for søndags-events)\n  4. focus: Skal nævne anledningen ved navn (fx "${bookingCriticalEvents[0].name_dk || bookingCriticalEvents[0].name}", ikke bare "helligdagen")\n\nEKSEMPEL - Mors Dag søndag:\n❌ FORKERT: focus: "Søndag formiddag som familiesamling", goal_mode: "retain_loyalty"\n✅ KORREKT: focus: "Torsdag-fredag eftermiddag trigger Mors Dag booking", goal_mode: "drive_footfall", content_direction: "Book bord til Mors Dag brunch — vis familier ved dækket bord", timing_window: "Thursday 14:00"`;
  }
  return '';
})()}
${context.previous_week.data_available && context.previous_week.top_post ? `Bedste post sidste uge: ${context.previous_week.top_post.content_type} (+${Math.round((context.previous_week.top_post.performance_vs_avg - 1) * 100)}%)` : ''}
${context.previous_week.selection_patterns && context.previous_week.selection_patterns.weeks_analyzed >= 1 ? (() => {
  const sp = context.previous_week.selection_patterns;
  // Apply floor of 15% so no goal_mode type can be squeezed out of the plan by history alone
  const FLOOR = 0.15;
  const rawRates = sp.goal_mode_rates as Record<string, number>;
  const floored = Object.fromEntries(Object.entries(rawRates).map(([k, v]) => [k, Math.max(v, FLOOR)]));
  const flooredTotal = Object.values(floored).reduce((s, v) => s + v, 0);
  const normalized = Object.fromEntries(Object.entries(floored).map(([k, v]) => [k, v / flooredTotal]));
  const rateLines = Object.entries(normalized)
    .sort((a, b) => (b[1] as number) - (a[1] as number))
    .map(([mode, rate]) => {
      const label = mode === 'drive_footfall' ? 'besøgsposter' : mode === 'build_brand' ? 'brandposter' : 'loyalitetsposter';
      return `  • ${Math.round((rate as number) * 100)}% ${label}`;
    }).join('\n');
  return `\n📊 HISTORISK BRUGERPRÆFERENCE (de seneste ${sp.weeks_analyzed} uge${sp.weeks_analyzed !== 1 ? 'r' : ''} — hvad brugeren faktisk valgte at publicere):\n${rateLines}\nBrug dette som blød indikator ved fordeling af mål-types. Alle tre typer skal altid repræsenteres i planen — historik kan justere vægtningen men ikke eliminere en type. Afvig kun fra vægten hvis denne uges kontekst (vejr, events, timing) taler kraftigt imod.`;
})() : ''}
${context.previous_week.posted_menu_items.length > 0 ? `\n⛔ DISSE MENUPUNKTER MÅ IKKE VÆLGES DENNE UGE (brugt inden for de seneste 1-2 uger):\n${context.previous_week.posted_menu_items.map((item: string) => `  • ${item}`).join('\n')}\nVælg andre retter fra menukortets kategorier.` : ''}
${context.owner_note ? `\n🗒️ EJERENS NOTE DENNE UGE (HØJESTE PRIORITET — lad dette forme hele planen):\n"${context.owner_note}"\nDette er en direkte instruktion fra ejeren. Reflektér den i week_summary, competitive_advantage og mindst én vinkels content_direction.` : ''}
${(() => {
  const pct = context.previous_week.posted_content_types as string[] | undefined;
  if (!pct || pct.length < 3) return '';
  const recent = pct.slice(-4); // look at last 4 posts
  const menuVisualCount = recent.filter(t => t === 'product_menu' || t === 'craving_visual').length;
  const humanCount = recent.filter(t => t === 'behind_scenes' || t === 'team_people').length;
  if (menuVisualCount >= 3 && humanCount === 0) {
    return `\n⛔ INDHOLDSTYPEBALANCE: De seneste ${recent.length} posts har haft ${menuVisualCount} mad/produkt-posts (product_menu/craving_visual) og ingen menneskeposter — denne uge SKAL inkludere mindst 1 post af typen \'behind_scenes\' eller \'team_people\' for at bevare variationen.`;
  }
  if (menuVisualCount >= 3) {
    return `\n💡 INDHOLDSTYPEBALANCE: Mange mad/produkt-posts de seneste uger (${menuVisualCount} af ${recent.length}) — overvej om slot C (brand builder) med fordel kan være \'behind_scenes\' eller \'team_people\' for at vise menneskene bag stedet.`;
  }
  return '';
})()}
${(() => {
  const psct = (context.previous_week as any).previous_slot_content_types as Array<{ slot_id: string; content_category: string }> | undefined;
  if (!psct || psct.length === 0) return '';
  const slotMap: Record<string, string> = {};
  for (const s of psct) slotMap[s.slot_id] = s.content_category;
  // Only show C and D — A and B (drive_footfall) are intentionally stable
  const slotLines = (['C', 'D'] as const)
    .map(id => slotMap[id] ? `  • Slot ${id} (${id === 'C' ? 'build_brand' : 'retain_loyalty'}): ${slotMap[id]}` : null)
    .filter(Boolean);
  if (slotLines.length === 0) return '';
  const allSame = slotLines.length === 2; // Only suggest rotation when we have both slots
  return `\n🔄 FORRIGE UGES INDHOLDSTYPEFORDELING (Slots C + D):\n${slotLines.join('\n')}\n${allSame ? `Undgå at "suggested_content_category" for build_brand- og retain_loyalty-vinkler gentager nøjagtig samme kombination som forrige uge.\nByt om — fx hvis forrige uge var C=team_people og D=behind_scenes, brug C=behind_scenes og D=team_people (eller craving_visual) denne uge.\nGentag kun samme type, hvis ingen anden type passer til ugens kontekst (events, mål, vejr).` : `Overvej at variere "suggested_content_category" for enten build_brand- eller retain_loyalty-vinklen i forhold til forrige uge.`}`;
})()}
${(() => {
  const pws = (context.previous_week as any).past_week_summaries as Array<{ week_number: number; week_summary: string; overview: string }> | undefined;
  if (!pws || pws.length === 0) return '';
  const entryLines: string[] = [];
  pws.forEach(s => {
    if (s.week_summary) entryLines.push(`Uge ${s.week_number}: "${s.week_summary}"`);
  });
  if (entryLines.length === 0) return '';
  const eventsLine = (context.events || []).length > 0
    ? (context.events || []).map((e: any) => e.name_dk || e.name).join(', ')
    : 'ingen events denne uge';
  return `\nFORRIGE UGERS UGSBESKRIVELSE (til reference — disse tekster er allerede sendt til ejeren):\n${entryLines.join('\n')}\n\nUGSDIFFERENTIERING — OBLIGATORISK FOR week_summary:\nDin week_summary SKAL indeholde mindst én sætning der specifikt beskriver NETOP DENNE uge og ikke ville passe til ugerne ovenfor.\nMulige differentierings-signaler (vælg det mest konkrete):\n  • Temperatur denne uge — skriv det faktiske tal, ikke "varmere/koldere"\n  • Nedbørsdage denne uge — antal og hvilke dage (se Nedbørsdage ovenfor)\n  • Events: ${eventsLine}\n  • Lønningsuge: ${context.economic.payday_this_week ? 'JA — gæsterne har mere at bruge af' : 'NEJ — normal forbrugsuge'}\n  • Ugeprofil: ${context.available_days?.length || 0} åbne dage — hverdags- eller weekendtung?\n  • Sæsonændring der sker præcis i denne uge\nFORBUDT GENTAGELSE: Ord-for-ord eller nær-identisk gentagelse af formuleringer fra ugerne ovenfor. Omskriv — selv hvis observationen er lignende.`;
})()}
${(() => {
  const paf = (context.previous_week as any).previous_angle_focuses as string[] | undefined;
  if (!paf || paf.length === 0) return '';
  return `\n📋 FORRIGE UGERS DOMINANTE VINKLER (blød vejledning — undgå direkte gentagelse):\n${paf.map((f: string) => `  • "${f}"`).join('\n')}\nHvis en af dine kandidat-vinkler ligner en af ovenstående (samme occasion-type, samme dagsdel, samme gæstetrigger), skal du enten:\n  a) Reframe den med et konkret anderledes udgangspunkt (anden dagdel, anden gæstetype, anderledes begivenhed)\n  b) Erstatte den med en lavere-vægtet kandidat der differentierer\nUndtagelse: Gentag gerne samme tema hvis denne uges kontekst (vejr, events, lønning) specifikt peger på netop den vinkel igen — men skriv den da anderledes (ny indgang, ny detalje, nyt konkret datapunkt).`;
})()}

${context.weather.has_outdoor_seating ? `UDESERVERING-REGLER (Danmark):
- Optimalt: 18-25°C, sol, svag vind, tørvejr
- Minimum: +15°C, sol, vindstille
- Forår (april/maj): Starter når +15°C, sol, vindstille
- Sommer (juni-august): Højsæson med høj sol og lune aftener
- Sensommer/efterår: Muligt når +15°C, sol, vindstille
- Under 15°C eller blæst/regn: Udeservering IKKE attraktiv
` : ''}

SKRIV PRÆCIST:
• Brug de faktiske tal fra data. Vejr skrives som: "7°C mandag, falder til 2°C torsdag" — ikke "koldt vejr".
• NEDBØRSPRÆCISION: Brug KUN 'Nedbørsdage'-listen for præcis nedbørsspand. Skyet/delvist skyet vejr er IKKE nedbør. Skriv ALDRIG "regn/sne mandag–onsdag" hvis Nedbørsdage kun viser mandag. Cloudy-dage er ikke nedbørsdage.
• Skriv som marketing-chef der briefer ejeren med konkrete fakta — ikke som konsulent der genererer slides.
• Undgå: positionere, facilitere, optimere, markant behov, kontinuerlig appel, appellerer til.
${context.week_modifiers?.overall_priority === 'quiet_normal' ? `
VIGTIG INSTRUKTION — STILLE NORMAL UGE:
Ingen events, intet lønningsskift og normalt vejr for måneden. Opfind IKKE dramatiske narrativer.
Vinkler skal være tætte og konkrete — fokusér på virksomhedens stærke baseline-argumenter, IKKE på kontekst der ikke er der.
Brug maksimalt ${Math.min(targetPostCount, 3)} vinkler. Undgå at fylde med svage vinkler der kun er der for at nå et antal.
` : ''}

${(() => {
  const candidatesV2 = (context as any).strategic_priority_candidates_v2 as Array<any> | undefined;
  if (!candidatesV2 || candidatesV2.length === 0) return '';
  const highConf = candidatesV2.filter((c: any) => c.confidence >= 0.70);
  const lines: string[] = [];
  lines.push('\nSTRATEGISKE KANDIDATER (forberegnet — confidence \u2265 0.70 SKAL adresseres):');
  candidatesV2.forEach((c: any) => {
    const marker = c.confidence >= 0.70 ? '\u2605' : '○';
    lines.push(`  ${marker} ${c.label} (${Math.round(c.confidence * 100)}%)`);
    lines.push(`     G\u00e6steadf\u00e6rd: ${c.customer_behavior_reason}`);
    lines.push(`     Forretning: ${c.business_reason}`);
  });
  if (highConf.length > 0) {
    lines.push(`\n  REGEL: De ${highConf.length} kandidater med \u2605 SKAL v\u00e6re repræsenteret i mindst ét fokusomr\u00e5de. Du v\u00e6lger formulering og framing — ikke indholdet af strategien.`);
  }
  return lines.join('\n');
})()}

${context.strategic_priority_candidates && context.strategic_priority_candidates.length > 0 && !(context as any).strategic_priority_candidates_v2?.length ? `UGENS PRIORITETER (forberegnet — brug som udgangspunkt, ikke som tvang):
${context.strategic_priority_candidates.map((p: string, i: number) => `  ${i + 1}. ${p}`).join('\n')}
` : ''}

${(() => {
  const cs = (context.brand_voice as any)?.content_strategy;
  if (!cs) {
    return `Skab ${targetPostCount} vinkler med variation — mix menu-retter, stemning og mennesker.`;
  }
  
  const primaryGoal = cs.primary_goal as 'drive_footfall' | 'build_brand' | 'retain_loyalty' | undefined;
  const gb = cs.week_goal_blend ?? cs.goal_blend;
  const cw = cs.week_content_category_weights ?? cs.content_category_weights;
  
  const goalLabels: Record<string, string> = {
    drive_footfall: '🏃 Tiltrækningsstrategi (drive footfall)',
    build_brand: '🎨 Brandopbygning (build brand)',
    retain_loyalty: '❤️ Loyalitetstrategi (retain regulars)'
  };
  
  const lines: string[] = [];
  lines.push('═══════════════════════════════════════════════');
  lines.push('STRATEGISK DIREKTIV (IKKE TIL FORHANDLING)');
  lines.push('═══════════════════════════════════════════════');
  lines.push('');
  
  if (primaryGoal) {
    lines.push(`PRIMÆRT MÅL: ${goalLabels[primaryGoal] || primaryGoal}`);
    lines.push('');
  }
  
  // Strategy rationale from brand profile
  if (cs.strategy_rationale) {
    lines.push('HVORFOR NETOP DENNE STRATEGI:');
    lines.push(cs.strategy_rationale);
    lines.push('');
  }
  
  // Concrete examples from signals/anchors/hooks
  if (Array.isArray(cs.footfall_signals) && cs.footfall_signals.length > 0) {
    lines.push('BESØGSSIGNALER (konkrete bevis for tiltrækningsstrategi):');
    cs.footfall_signals.forEach((s: string) => lines.push(`  • ${s}`));
    lines.push('');
  }
  
  if (Array.isArray(cs.brand_anchors) && cs.brand_anchors.length > 0) {
    lines.push('BRAND-ELEMENTER (signatur der kræver synlighed):');
    cs.brand_anchors.forEach((a: string) => lines.push(`  • ${a}`));
    lines.push('');
  }
  
  if (Array.isArray(cs.loyalty_hooks) && cs.loyalty_hooks.length > 0) {
    lines.push('LOYALITETS-VANER (ritualer der understøtter fastholdelse):');
    cs.loyalty_hooks.forEach((h: string) => lines.push(`  • ${h}`));
    lines.push('');
  }
  
  // Timing guidance based on primary_goal and booking occasions
  lines.push('═══════════════════════════════════════════════');
  lines.push('TIMING-FILOSOFI (OBLIGATORISK)');
  lines.push('═══════════════════════════════════════════════');
  lines.push('');
  
  // Check for booking-critical events
  const bookingCriticalEvents = (context.events || []).filter((e: any) => {
    const name = (e.name_dk || e.name || '').toLowerCase();
    const isBookingCritical = (
      name.includes('mors dag') ||
      name.includes('fars dag') ||
      name.includes('valentinsdag') ||
      name.includes('nytår') ||
      name.includes('jul') ||
      name.includes('påske') ||
      (e.commercial_weight ?? 0) >= 8
    );
    return isBookingCritical && e.in_week !== false;
  });
  
  const isFirstWeekendOfMonth = (() => {
    const weekStart = new Date(context.week_start);
    const monthStart = new Date(weekStart.getFullYear(), weekStart.getMonth(), 1);
    const daysDiff = Math.floor((weekStart.getTime() - monthStart.getTime()) / (1000 * 60 * 60 * 24));
    return daysDiff <= 7;
  })();
  
  const isDecember = new Date(context.week_start).getMonth() === 11;
  
  const needsBookingFocus = bookingCriticalEvents.length > 0 || (isFirstWeekendOfMonth && primaryGoal === 'drive_footfall') || isDecember;
  
  if (needsBookingFocus) {
    lines.push('🔴 BOOKING-FOKUS DENNE UGE:');
    if (bookingCriticalEvents.length > 0) {
      lines.push(`  Anledning: ${bookingCriticalEvents.map((e: any) => e.name_dk || e.name).join(', ')}`);
    }
    if (isFirstWeekendOfMonth) {
      lines.push('  Første weekend i måneden — øget booking-demand');
    }
    if (isDecember) {
      lines.push('  December — julefrokost/julefest booking-sæson');
    }
    lines.push('');
    lines.push('DRIVE_FOOTFALL posts SKAL inkludere BOOKING CTA:');
    lines.push('  • "Book bord", "Reservér plads", "Ring og book" i content_direction');
    lines.push('  • Timing 1-3 dage FØR selve dagen (torsdag-fredag for søndags-events)');
    lines.push('  • Nævn anledningen eksplicit (fx "Mors Dag", ikke bare "søndagen")');
    lines.push('');
  }
  
  lines.push('GENEREL TIMING-PRINCIP: Posts når gæster BESLUTTER, ikke når de forbruger');
  lines.push('');
  
  if (primaryGoal === 'drive_footfall') {
    lines.push('DRIVE_FOOTFALL timing (beslutnings-vindue):');
    if (needsBookingFocus) {
      lines.push('  • Booking posts → 1-3 dage før event (se ovenfor)');
    }
    lines.push('  • Frokost → post 11:00-12:00 (før frokostvalg kl. 12-14)');
    lines.push('  • Aften → post 15:00-16:00 (eftermiddags planlægning)');
    lines.push('  • Weekend brunch → post fredag 17:00 (weekend planning window)');
    lines.push('  • Cocktails → post 16:00 (after-work beslutning)');
  } else if (primaryGoal === 'build_brand') {
    lines.push('BUILD_BRAND timing (educational moments):');
    lines.push('  • Storytelling → post 09:00-10:00 (morgen engagement)');
    lines.push('  • Behind scenes → post 14:00-16:00 (eftermiddags browsing)');
    lines.push('  • Brand narrative → post hverdage (ikke peak booking-dage)');
  } else if (primaryGoal === 'retain_loyalty') {
    lines.push('RETAIN_LOYALTY timing (community moments):');
    lines.push('  • Genkendelse → post 10:00-11:00 (casual browsing)');
    lines.push('  • Thank you → post mandag-tirsdag (start af ugen)');
    lines.push('  • Insider moments → post onsdag-torsdag (mid-week connection)');
  }
  lines.push('');
  
  // Goal blend - make it MANDATORY
  lines.push('═══════════════════════════════════════════════');
  lines.push('MÅL-FORDELING (OBLIGATORISK FOR DENNE UGE)');
  lines.push('═══════════════════════════════════════════════');
  lines.push('');
  
  if (gb) {
    const total = (gb.drive_footfall ?? 0) + (gb.build_brand ?? 0) + (gb.retain_loyalty ?? 0);
    if (total > 0) {
      const df = Math.round((gb.drive_footfall ?? 0) / total * 100);
      const bb = Math.round((gb.build_brand ?? 0) / total * 100);
      const rl = Math.round((gb.retain_loyalty ?? 0) / total * 100);
      
      lines.push(`Mål-fordeling fra brand-profil:`);
      lines.push(`  • ${df}% drive_footfall (besøgsdrivende)`);
      lines.push(`  • ${bb}% build_brand (brandopbygning)`);
      lines.push(`  • ${rl}% retain_loyalty (loyalitet)`);
      lines.push('');
      
      // Calculate exact post counts
      const dfCount = Math.round(targetPostCount * (gb.drive_footfall ?? 0) / total);
      const bbCount = Math.round(targetPostCount * (gb.build_brand ?? 0) / total);
      const rlCount = targetPostCount - dfCount - bbCount;
      
      lines.push(`For ${targetPostCount} posts betyder det PRÆCIS:`);
      lines.push(`  → ${dfCount} vinkler med goal_mode: "drive_footfall"`);
      lines.push(`  → ${bbCount} vinkler med goal_mode: "build_brand"`);
      lines.push(`  → ${rlCount} vinkler med goal_mode: "retain_loyalty"`);
      lines.push('');
      lines.push('⚠️ DU MÅ IKKE afvige fra denne fordeling uden EKSPLICIT årsag i reasoning.');
      lines.push('   Acceptable årsager: ekstraordinær booking-uge, stor begivenhed, åbningsuge.');
      lines.push('   Uacceptable: "vejret er godt", "stemningen passer".');
    }
  }
  
  // Content category weights
  if (cw) {
    lines.push('');
    lines.push('INDHOLDSTYPE-FORDELING (vejledende):');
    const catLabels: Record<string, string> = {
      product_menu: 'produkt (specifik ret)',
      craving_visual: 'stemningsfulde madbilleder',
      behind_scenes: 'bag-om/køkken',
      team_people: 'menneskeposts',
    };
    const cats = (['product_menu', 'craving_visual', 'behind_scenes', 'team_people'] as const)
      .map(k => [k, cw[k] ?? 0] as [string, number])
      .filter(([, v]) => v > 0)
      .sort((a, b) => b[1] - a[1]);
    const catTotal = cats.reduce((s, [, v]) => s + v, 0);
    if (catTotal > 0) {
      cats.forEach(([k, v]) => {
        lines.push(`  • ${Math.round(v / catTotal * 100)}% ${catLabels[k]}`);
      });
    }
  }
  
  lines.push('');
  lines.push('═══════════════════════════════════════════════');
  
  return lines.join('\n');
})()}

${(() => {
  const guardrails = (context as any).narrative_guardrails as string[] | undefined;
  if (!guardrails || guardrails.length === 0) return '';
  return `SPROGLIGE GUARDRAILS (UFRAVIGELIGE — gælder for AL tekst i denne brief):\n${guardrails.map((g: string) => `  • ${g}`).join('\n')}\n`;
})()}
${(() => {
  const weekMode   = (context as any).week_mode as string | undefined;
  const deprioList = (context as any).deprioritize as string[] | undefined;
  const parts: string[] = [];
  if (weekMode && weekMode !== 'standard_week') {
    parts.push(`UGENS TILSTAND: ${weekMode.replace(/_/g, ' ')}`);
    // Add concrete commercial framing guidance per week_mode type
    if (weekMode.includes('indoor_refuge')) {
      parts.push(`KOMMERCIEL FORTOLKNING AF INDOOR_REFUGE: Regnfuldt/koldt vejr reducerer spontan udegang. For denne virksomhed betyder det øget sandsynlighed for planlagte frokostbesøg og kaffepause-besøg indenfor. Framing skal handle om BESØGSKONKURRENCEN (hvorfor vælge netop dette sted frem for ingen tur) — ikke om vejret som stemning.`);
    } else if (weekMode.includes('terrace')) {
      parts.push(`KOMMERCIEL FORTOLKNING AF TERRACE: Godt vejr øger spontan udegang og terrasse-trafik. Framing skal handle om det konkrete udendørs tilbud og hvornår på dagen det er bedst — ikke om "sommerfølelse" eller generel glæde.`);
    } else if (weekMode.includes('takeaway')) {
      parts.push(`KOMMERCIEL FORTOLKNING AF TAKEAWAY: Vejret øger demand for mad man tager med frem for at spise ude. Framing skal handler om convenience, hurtig ekspedition og konkret takeaway-tilbud — ikke om vejret som barriere.`);
    }
  }
  if (deprioList && deprioList.length > 0) {
    parts.push(`DEPRIORITÉR DENNE UGE: ${deprioList.join(', ')}\nDisse vinkler skal IKKE tildeles kapacitet — de har lav relevans for denne virksomhed i denne uge.`);
  }
  return parts.length > 0 ? parts.join('\n') + '\n' : '';
})()}
${/* MODE: 'brief' — Strategy-level forbidden phrases (includes hygge exception, seasonal phrases, DB-word block)
      Applied at Phase 1 (strategic brief generation) to validate strategy narrative output.
      Different from Phase 2 'post' mode which validates individual post fields. */
   buildForbiddenBlock('brief')}

═══════════════════════════════════════════════
STRATEGISK ARBEJDSPROCES (FØLG DENNE RÆKKEFØLGE)
═══════════════════════════════════════════════

FØR du skriver din strategi, arbejd dig gennem disse 6 trin systematisk:

STEP 1 — KONTEKSTUEL INVENTARLISTE (comprehensive scan):
  List ALLE unikke faktorer denne uge der afviger fra en baseline-uge:
  □ Tids-baserede: helligdage, klemmedage, lønningsuge, uge-i-måneden
  □ Vejr: temperatur-shifts, nedbørsmønstre, udendørs-viability per dag
  □ Adfærdsmæssige: hvad hver faktor muliggør/begrænser for forskellige kundesegmenter

  UNDGÅ: At stoppe ved første identificerede faktor. Scan komplet.

STEP 2 — MULIGHEDS-MAPPING (multi-dimensional):
  For HVER faktor fra Step 1, besvar:
  □ Hvilke kunde-adfærder muliggør dette? (frokost/middag/socialt/fejring/familie)
  □ Hvilke tidsvinduer aktiveres? (middag/aften/weekend/multi-dags)
  □ Hvem er primær målgruppe? (familier/medarbejdere/par/grupper)

  EKSEMPEL - Torsdag helligdag:
    ✗ NARROW: "Øger frokosttrafik torsdag"
    ✓ COMPREHENSIVE: "Aktiverer 3 vinduer: (1) Torsdag frokost (familier, butikker lukket), 
       (2) Torsdag aften (fejring, ingen arbejde fredag for mange), 
       (3) Fredag (klemmedag = forlænget weekend, både frokost OG aften)"

STEP 3 — KRYDS-FAKTOR SYNTESE (find sammensatte muligheder):
  Identificer synergier — hvilke faktorer kombinerer til compound opportunities?
  
  EKSEMPEL - Kr. Himmelfartsdag Torsdag + typical_bridge_day + 16°C Fredag + waterfront location:
    = 4-dages celebrations-vindue (frokost-surge + aften-fejring + fredag bridge day leisure)
    IKKE bare "torsdag frokost" alene.

  □ Hvilke 2-3 faktorer forstærker hinanden?
  □ Hvilket multi-dags mønster opstår?
  □ Hvad er det fulde tidsvindue (ikke kun én dag)?

STEP 4 — FORRETNINGS-FIT FILTER:
  Hvilke muligheder matcher denne virksomheds:
  □ Servicetider (${(context as any).menu_programmes?.map((p: any) => p.role).join(', ') || 'se Driftsprogrammer'})
  □ Menu-styrker (se MENUER section ovenfor)
  □ Lokations-fordele (${context.city}${(context.location as any).type ? `, ${(context.location as any).type}` : ''})
  □ Brand-positionering (${context.v5_identity ? 'se V5 BRAND IDENTITY' : 'se brand voice'})

STEP 5 — STRATEGISK PRIORITERING:
  Rank muligheder efter:
  □ Kunde-demand styrke (high/medium/low)
  □ Forretnings-capability fit (strong/moderate/weak)  
  □ Unikhed denne uge (gælder ikke andre uger)

  BALANCE-REGEL: Max 2 drive_footfall posts ved 4-posts uge (publikumstræthed).
                  Afvig kun ved booking-kritisk uge — angiv årsag eksplicit.

STEP 6 — POST-PLAN ALLOKERING:
  Givet ${targetPostCount} posts, distribuér på tværs af top-muligheder og sikr:
  □ Hver post adresserer et specifikt tidsvindue
  □ goal_mode balance afspejler content_strategy weights
  □ Ingen major mulighed ignoreres
  □ Multi-dags mønstre får tilstrækkelig coverage

═══════════════════════════════════════════════
FEW-SHOT EKSEMPEL: STELLAR STRATEGI
═══════════════════════════════════════════════

SCENARIE: Kr. Himmelfartsdag Torsdag 14. maj + typical_bridge_day + 16°C fredag + waterfront café

❌ NARROW APPROACH (forkert — single-dimension thinking):
{
  "week_summary": "Kr. Himmelfartsdag torsdag øger frokosttrafik. Prioritér frokostposts.",
  "competitive_advantage": "Netop denne uge er fordelen, at vi har god mad og hyggelig atmosfære.",
  "angles": [
    {"focus": "Frokost på Kristi Himmelfartsdag", "weight": 0.6, "goal_mode": "drive_footfall"},
    {"focus": "Weekend brunch", "weight": 0.4, "goal_mode": "drive_footfall"}
  ]
}
↑ PROBLEMER: 
  • Kun frokost-fokus (misser aften + fredag bridge day)
  • Generisk competitive_advantage (passer på 20 andre steder)
  • Ingen syntese mellem helligdag + klemmedag + vejr + waterfront

✅ COMPREHENSIVE APPROACH (korrekt — multi-dimensional synthesis):
{
  "contextual_analysis": {
    "unique_factors_this_week": [
      {
        "factor": "Kr. Himmelfartsdag Thursday + typical_bridge_day",
        "customer_behavior_enabled": "4-day weekend (Thu-Sun), celebration mode Thursday evening, leisure mode Friday all-day",
        "time_windows_activated": ["Thursday 11:00-15:00", "Thursday 17:00-22:00", "Friday 10:00-22:00"],
        "audience_segments": ["families (lunch)", "groups (evening)", "couples (Friday)"]
      },
      {
        "factor": "16°C Friday + waterfront location",
        "customer_behavior_enabled": "Outdoor dining appeal, extended evening stays",
        "time_windows_activated": ["Friday 17:00-21:00"],
        "audience_segments": ["couples", "after-work groups"]
      }
    ],
    "opportunity_synthesis": "Thursday holiday surge + Friday bridge day + good weather + waterfront = dual opportunity: (1) lunch gatherings Thu-Fri, (2) evening celebration Thu + leisurely Friday dining. This is a 4-day window, not just Thursday lunch."
  },
  "week_summary": "Kr. Himmelfartsdag torsdag og typisk klemmedag fredag skaber 4-dages vindue: Butikker lukket torsdag øger frokost-trafik 11-15, men mange har fri fredag hvilket også aktiverer aftenbesøg torsdag 17-22 (fejring, ingen arbejde næste dag) og hele fredagen (leisure-mode frokost + aften). Caféens åbningstid fra brunch til aftenservering og placering ved åen matcher præcis denne dobbelte surge — ikke kun frokost, men også aften-/fredag-segmentet. Prioritér frokost-CTA onsdag-torsdag formiddag + aften-content torsdag eftermiddag + fredag waterfront-stemning. Weekend-brunch er standard-flow uden helligdags-boost.",
  "competitive_advantage": "Netop denne uge er fordelen, at caféen dækker brunch-til-aften-service (11-22) — Kr. Himmelfartsdag aktiverer primært frokost-segmentet torsdag, men klemmedag-mønsteret rykker også aftenbesøg ind i samme vindue. Waterfront-placeringen giver ekstra pull fredag ved 16°C (outdoor seating appeal uden høj-sommer priser).",
  "angles": [
    {
      "focus": "Planlagt frokostbesøg torsdag-fredag (helligdag + klemmedag)",
      "weight": 0.35,
      "goal_mode": "drive_footfall",
      "reasoning": "Kr. Himmelfartsdag torsdag (butikker lukket, familier søger restaurantbesøg) + mange tager fredag fri = 2-dages frokost-surge. Caféens klassiske frokostmenukort og åbningstid 11-22 matcher præcis. Uge-relevans: Ikke standard hverdagsfrokost — dette er planlagte helligdags-/klemmedags-besøg.",
      "content_direction": "product_menu fordi surge-vindue kræver konkret ret + booking-CTA — vis dampende varm hovedret (fx bøf/pasta) med synlige ingredienser i dagslys — trigger booking-intention onsdag-torsdag formiddag før frokost-rush"
    },
    {
      "focus": "Aftenbesøg torsdag-fredag (fejringsmode + bridge day leisure)",
      "weight": 0.35,
      "goal_mode": "drive_footfall",
      "reasoning": "Torsdag aften aktiveret af 'ingen arbejde fredag'-mønster (fejring, social) + fredag aften aktiveret af forlænget weekend-stemning. Caféens cocktail-menu og waterfront-placering giver eveningappeal. Uge-relevans: Ikke standard weekend-aften — 4-dages vindue starter torsdag.",
      "content_direction": "craving_visual fordi aften-stemning > specifik ret — vis cocktails i aftenbelysning ved vindue/waterfront, fokus på glassene og lyset — trigger spontant besøg torsdag-fredag 17-21"
    },
    {
      "focus": "Åbningsritual mandag (brand-kontinuitet efter 4-dages surge)",
      "weight": 0.15,
      "goal_mode": "build_brand",
      "reasoning": "Efter 4-dages helligdags-vindue returnerer stamgæster til normal uge-rytme mandag. Behind-scenes morgenritual bygger genkendelse. Uge-relevans: Signalerer 'tilbage til normal drift' efter atypisk uge.",
      "content_direction": "behind_scenes fordi slot C mandag er brand-post — vis det konkrete morgenritual før åbning (fx borddækning, kaffeopsætning), ikke mad — aktivér loyalitet via genkendelse mandag 09:00"
    },
    {
      "focus": "Weekend brunch lørdag-søndag (standard flow)",
      "weight": 0.15,
      "goal_mode": "retain_loyalty",
      "reasoning": "Weekend-brunch er baseline-tilbud uden helligdags-boost (Kr. Himmelfartsdag var torsdag). Caféens brunch-menu er etableret weekend-ritual. Uge-relevans: Maintain kontinuitet — ikke primær surge-vinkel denne uge.",
      "content_direction": "product_menu fordi weekend-brunch kræver konkret ret-inspiration — vis klassisk brunch-ret (fx æggekage) i morgenlys — fasthold stamgæster via genkendelse lørdag 09:00"
    }
  ]
}
↑ HVORFOR DETTE ER STELLAR:
  • Identificerer 4-dages vindue (ikke kun torsdag)
  • Adresserer BÅDE frokost OG aften (double opportunity)
  • Syntetiserer helligdag + klemmedag + vejr + waterfront
  • competitive_advantage er specifik for DENNE virksomhed DENNE uge
  • Reasoning forklarer adfærd + fit + uge-relevans for hver vinkel

═══════════════════════════════════════════════
STRATEGISK AUDIT (OBLIGATORISK FØR OUTPUT)
═══════════════════════════════════════════════

FØR du sender din strategi, tjek disse punkter:

1. MULTI-DIMENSIONAL CHECK:
   □ Har jeg identificeret muligheder for FLERE tidsvinduer (ikke kun én dagsdel)?
   □ Hvis der er en torsdag-helligdag med typical_bridge_day, har jeg overvejet fredag-adfærd?
   □ Hvilke multi-dags mønstre findes (ikke kun single-dag peaks)?

2. SYNTHESIS CHECK:
   □ Kombinerer jeg flere kontekst-faktorer (vejr + helligdag + location + menu)?
   □ Eller bruger jeg dem isoleret (kun vejr, eller kun helligdag)?
   □ Har jeg fundet compound opportunities (2+ faktorer der forstærker hinanden)?

3. UNIQUENESS CHECK:
   □ Kunne denne strategi bruges til 3 andre virksomheder DENNE uge? → UGYLDIG
   □ Kunne denne strategi bruges til DENNE virksomhed 3 andre uger? → MANGLER unikhed
   □ Hvilke SPECIFIKKE data fra DENNE uge driver prioriteringerne?

4. COMPLETENESS CHECK:
   □ Har jeg overvejet ALLE tidsvinduer aktiveret af ugens kontekst?
   □ Er der en oplagt mulighed jeg ignorerer (fx aften når jeg fokuserer på frokost)?
   □ Balance: Max 2 drive_footfall ved 4 posts — er der en god grund til at afvige?

5. SYNTHESIS QUALITY CHECK:
   □ Nævner week_summary mindst 2 faktorer og deres interaktion (ikke kun én faktor)?
   □ Forklarer competitive_advantage HVORFOR denne virksomhed passer til denne uges mønster?
   □ Indeholder contextual_analysis både opportunity identification OG synthesis?

HVIS DU SVARER "NEJ" eller "USIKKER" på nogen af disse:
→ REVIDER din strategi. En CMO ville aldrig præsentere en strategi med gaps.

═══════════════════════════════════════════════
OUTPUT STRUKTUR OG REGLER
═══════════════════════════════════════════════

REGLER:
1. Lav præcis ${targetPostCount} fokus-områder — ét per post denne uge.
   
   FOKUS-NAVN ("focus"-felt) — se eksempel ovenfor:
   - Handlingsorienteret + observerbar adfærd/dagsdel + konkret mekanisme
   - Formel: [dagsdel/adfærd] + [situation/mekanisme]
   - Se stellar eksempel: "Planlagt frokostbesøg torsdag-fredag (helligdag + klemmedag)"
   
   FORBUDT i focus: abstrakte stemningsord ("hygge", "oase", "fristed"), vejr som suffix/prefix, 
   lokation som dekoration, generiske navne uden mekanisme.
   PRINCIP: Navnet beskriver adfærd. Vejret/lokationen forklares i reasoning.

2. Hvert område SKAL bruge: brand profile + menu + vejr/events + timing
3. reasoning = 2-4 sætninger — se FELT: angles[].reasoning nedenfor for de tre obligatoriske forankringspunkter.
4. Nævn ALDRIG specifikke menu-retter (kun kategorier som "varme retter", "klassikere")
5. Mindst ét fokus-område skal åbne for oplevelse-posts (ikke kun produkt): fx "Placeringen ved [lokationsfordel] som møde- og destinationsargument", "Morgenens åbningsritual", "Bag ved disken på en regnfuld tirsdag"
6. competitive_advantage: Se krav nedenfor i JSON-instruktionen
7. Vægte summer til 1.0
8. Nævn KUN konkrete ingredienser/råvarer hvis de fremgår af "Menustøttede sæsonråvarer" fra konteksten. Brug sæsonatmosfære-signaler til framing og stemning — ikke til specifikke ingrediensløfter.
9. INDHOLDSKOMPOSITION — bestem selv pr. vinkel, men argumér i reasoning:
   a) goal_mode — PRÆCIS ét af:
      "drive_footfall" — øg besøg nu (hård CTA, booking, åbningstid)
      "build_brand"    — opbyg kendskab og tillid (blød CTA, personlighed, brand)
      "retain_loyalty" — fasthold stamgæster (ingen CTA, genkendelse, varme)
      BALANCEREGEL: Maksimalt 2 × drive_footfall ved 4 posts. Afvig kun ved ekstraordinær uge — angiv årsag.
   b) content_type — PRÆCIS ét af:
      "menu_item"     — specifik ret fra menuen (kræver menu-data i Phase 2)
      "atmosphere"    — stemning, sted, udsigt (ingen specifik ret)
      "behind_scenes" — køkken, forberedelse, mennesker (kun hvis noget konkret at vise)
      "seasonal"      — sæsonmoment uden specifik ret
   c) timing_window — publiceringsvindue som "Dag(e) TT:MM" — fx "Thu-Fri 14:00", "Mon 09:00", "Wed 11:00"
${(() => {
  const activeOccasions = (context as any).active_occasions_this_week as import('../occasions/occasion-library.ts').ActiveOccasion[] | undefined;
  if (activeOccasions && activeOccasions.length > 0) {
    return `      TILDELTE OCCASIONS DENNE UGE — brug resolved_post_timing fra occasion som timing_window for den matchende vinkel.
      Rækkefølge svarer til prioritet (occasion 1 = vigtigst):
${activeOccasions.map((o, i) =>
  `      ${i + 1}. ${o.occasion_id} | timing: ${o.resolved_post_timing} | mål: ${o.goal_mode} | cta: ${o.resolved_cta} | "${o.label_dk}"`
).join('\n')}
      REGEL 9c: Når en occasion er tildelt en vinkel (match på goal_mode + content_type), KOPIER resolved_post_timing præcist som timing_window. Du MÅ IKKE opfinde et nyt tidspunkt. Mund-til-mund-reglen: hvis du er i tvivl, tag timingen fra occasion nr. 1 til din vigtigste vinkel.`;
  }
  return `      Brug TILGÆNGELIGE DAGE som reference. Foretræk platformens peak-engagement-tidspunkt for content_type.`;
})()}
   d) promoted_moment — på dansk: hvilken serviceperiode eller besøgstype posten promoverer
      Dette adskiller publiceringstidspunktet fra det der promoveres:
      ✓ "aftenservering torsdag–lørdag" (post publiceres 14:00, fremmer aftenbesøg)
      ✓ "frokostpause hverdage 12–14", "weekendbrunch lørdag–søndag", "spontant besøg i dag"

─────────────────────────────────────────────────────────
FELT: week_summary
─────────────────────────────────────────────────────────
Præcis 3–4 sætninger. Struktur OBLIGATORISK — en sætning per punkt:

  SÆT. 1 — ADFÆRDSÆNDRING (ikke vejrbeskrivelse):
    Hvad ændrer sig i gæsternes adfærd denne uge, og hvornår?
    ✓ "7°C og regn mandag–onsdag øger spontane [primær dagsdel]-besøg indendørs [tidspunkt fra profil]"
    ✗ "Vejret er koldt og udfordrende denne uge" / "Foråret er på vej og stemningen er god" (deskriptivt/atmosfære — ikke adfærd)

  HELLIGDAG/FERIE-REGEL — OBLIGATORISK (overskriver normale prioriteringer):
    Hvis Events-listen indeholder en helligdag (★★★) eller en skoleferie, SKAL SÆT. 1 nævne begivenheden ved navn som den primære adfærdsdriver.
    Vejr og lønning er sekundære signaler — de kan nævnes i SÆT. 2–3, men ALDRIG som primærdriver i SÆT. 1 når en helligdag er til stede.
    ✓ "Påskeferie og Skærtorsdag torsdag skifter ugens rytme — familier er fri og søger restaurantoplevelser onsdag–søndag"
    ✓ "Langfredag og Påskesøndag definerer ugen — lukket eller reduceret drift giver anledning til tidlig kommunikation om åbningstider og særmenu"
    ✗ "Regn alle dage og lønningsuge fra tirsdag..." (ignorerer tilstedeværende helligdag — UGYLDIG hvis helligdag er i Events)

  SÆT. 2 — VIRKSOMHEDSSPECIFIK KOMMERCIEL IMPLIKATION (DENNE UGE — IKKE ALTID):
    Svar på: Hvorfor matcher NETOP DENNE virksomhed den adfærdsændring NETOP DENNE UGE?
    Vælg det mest uge-specifikke anker — mindst ét skal skifte uge til uge:
      • Hvilken servicetid bærer belastningen denne uge? (dagsdel + konkret tidsrum fra profil)
      • Er det primært en hverdags- eller weekendstyret uge — og hvad giver det dette sted?
      • Hvad er en konkret egenskab ved stedet der præcis matcher DENNE uges dominante mønster?
    TEST 1: Passer sæt. 2 på 20 andre spisesteder? → Ugyldig. Skriv om.
    TEST 2: Er sæt. 2 sand HVER eneste uge uanset vejr og events? → Ugyldig. Tilføj det uge-specifikke anker.
    TEST 3 (VARIABELT ELEMENT): Sæt. 2 SKAL indeholde mindst ét element der bogstaveligt skifter fra uge til uge — dvs. et konkret tal (°C, antal regndage), en specifik ugedag ("torsdag", "weekenden"), et event-navn eller lønningsuge-status. Åbningstider, beliggenhed og servicetype er ALDRIG variable nok — de er sande hver eneste uge.
    ⛔ FORBUDT MØNSTER — "netop denne uges rytme", "matcher ugens profil", "passer til denne uge": disse er temporale markører der lyder specifikke men ikke indeholder nogen variabel data. Ingen af dem består TEST 3.
    ✓ "[Navn] dækker [konkret tidsrum fra profil] — regn mandag og søndag (+[X]mm) øger sandsynlighed for planlagte aftenbesøg præcis i dette spænd"
    ✓ "Med 16°C torsdag og 7°C lørdag er spændvidden [X] grader bredere end normalt — [Navn]s indendørs format bærer alle dagsdele"
    ✗ "[Navn] er stedet der altid tilbyder god mad og god stemning" / "Beliggenheden ved åen gør stedet attraktivt" (statisk)
    ✗ "[Navn]s åbning fra brunch til nat matcher netop denne uges rytme" (åbningstider er statiske — "netop denne uges rytme" er tom temporal markør)

  SÆT. 3 — KONKRET KOMMERCIEL PRIORITET DENNE UGE:
    Hvad er det ene præcise taktiske træk: dagsdel + menu-kategori + content-vinkel.
    ✓ "Prioritér [primær dagsdel]-CTA [hverdage] [tidspunkt fra profil] med fokus på [relevant menukategori]"
    ✗ "Content denne uge bør fokusere på mad og oplevelser" (ikke konkret)

  SÆT. 4 — VALGFRI DE-PRIORITERING:
    Kun hvis der er noget der konkret skal nedprioriteres denne uge.
    Udelad hvis ingen reel modvægt eksisterer.

FORBUDT i dette felt:
─────────────────────────────────────────────────────────
FELT-INSTRUKTIONER (se stellar eksempel ovenfor for alle felter)
─────────────────────────────────────────────────────────

FELT: week_summary
  Præcis 3–4 sætninger. Struktur:
  SÆT. 1: Adfærdsændring (hvad ændrer sig, hvornår)
  SÆT. 2: Virksomhedsspecifik fit (DENNE virksomhed + DENNE uge)
  SÆT. 3: Konkret kommerciel prioritet (dagsdel + timing + menu)
  SÆT. 4: Valgfri de-prioritering
  
  KRITISK: Helligdag/ferie-regel — hvis Events-listen har ★★★, SKAL SÆT. 1 nævne begivenheden ved navn.
  Se stellar eksempel for hvordan 4-dages vindue beskrives (ikke kun én dag).

FELT: competitive_advantage
  2 sætninger. Start ALTID: "Netop denne uge er fordelen, at …"
  Kræver mindst 2 fit-dimensioner: lokation/servicetid/driftsmodel/besøgsmotiv/ugespecifik.
  Se stellar eksempel: specifikke tidsspænd + konkret fit-argumentation.

FELT: angles[].reasoning
  2-4 sætninger. Alle 3 punkter SKAL være til stede:
  a) Adfærd: Observerbar gæsteadfærdsændring
  b) Virksomhedsfit: Hvorfor NETOP denne virksomhed matcher
  c) Uge-relevans: Hvorfor NETOP denne vinkel denne uge
  Se stellar eksempel: Kr. Himmelfartsdag reasoning viser alle 3 punkter.

FELT: angles[].content_direction
  3 dele (adskil med " — "):
  a) Format-valg fordi [konkret fit-argument]
  b) Kreativ kerne [specifikt, observerbart øjeblik]
  c) Gæste-handling [præcis adfærd + timing]
  Se stellar eksempel: "product_menu fordi... — vis dampende varm hovedret... — trigger booking-intention..."

${(() => {
  const weekMode = (context as any).week_mode as string | undefined;
  if (!weekMode || weekMode === 'standard_week') return '';
  const lines: string[] = ['─────────────────────────────────────────────────────────'];
  lines.push(`AKTIV UGE-FRAMING: ${weekMode.replace(/_/g, ' ').toUpperCase()}`);
  if (weekMode.includes('indoor_refuge')) {
    lines.push('→ Vejret i ALLE felter: beskriv som besøgsmekanisme (hvornår, hvem, sandsynlighed for besøg) — IKKE som stemning, kulisse eller hygge-argument.');
    lines.push('→ Venue-atmosfære som konkurrencefordel er FORTSAT TILLADT — men skal bindes til en konkret egenskab (interiørform, siddearrangement, driftsmodel), ikke til vejret.');
  } else if (weekMode.includes('terrace')) {
    lines.push('→ Vejret i ALLE felter: beskriv det konkrete udendørs tilbud og hvornår på dagen det er optimalt — IKKE som "sommerfølelse" eller generel naturglæde.');
    lines.push('→ Terrasse-stemning som konkurrencefordel er TILLADT — bind det til konkret dagsdel, kapacitet eller siddearrangement.');
  } else if (weekMode.includes('takeaway')) {
    lines.push('→ Vejret i ALLE felter: beskriv convenience, ekspeditionshastighed og konkret tilbud — IKKE vejret som stemnings-barriere for udegang.');
    lines.push('→ Vurder om venue-atmosfære er relevant denne uge, eller om besøgsincitamentet er rent convenience-drevet.');
  }
  lines.push('─────────────────────────────────────────────────────────');
  return lines.join('\n') + '\n';
})()}
═════════════════════════════════════════════════════════
OUTPUT-PROCES (FØLG DENNE RÆKKEFØLGE)
═════════════════════════════════════════════════════════

TRIN 1 — UDFYLD CONTEXTUAL_ANALYSIS FØRST:
Før du skriver week_summary, competitive_advantage eller angles, SKAL du først udfylde:
  {
    "contextual_analysis": {
      "unique_factors_this_week": [ ... ],  // mindst 2 faktorer
      "opportunity_synthesis": "..."         // hvordan de kombineres
    }
  }

Dette felt er IKKE valgfrit. Det dokumenterer Step 1-3 i den strategiske proces.
STOP hvis du ikke kan udfylde dette — så mangler du grundlaget for strategien.

TRIN 2 — BRUG CONTEXTUAL_ANALYSIS TIL AT SKRIVE RESTEN:
Nu kan du skrive week_summary, competitive_advantage og angles baseret på din analyse.

═════════════════════════════════════════════════════════
JSON OUTPUT STRUKTUR
═════════════════════════════════════════════════════════

SVAR I JSON-FORMAT (præcis ${targetPostCount} objekter i "angles"):
{
  \"contextual_analysis\": {
    \"unique_factors_this_week\": [
      {
        \"factor\": \"[navn på faktor, fx 'Kr. Himmelfartsdag Thursday + typical_bridge_day']\",
        \"customer_behavior_enabled\": \"[hvilke kunde-adfærder muliggøres — fx '4-day weekend, celebration mode Thursday, leisure Friday']\",
        \"time_windows_activated\": [\"Thursday 11:00-15:00\", \"Thursday 17:00-22:00\", \"Friday 10:00-22:00\"],
        \"audience_segments\": [\"families\", \"groups\", \"couples\"]
      }
    ],
    \"opportunity_synthesis\": \"[Hvordan kombinerer 2+ faktorer til compound opportunities? Beskriv det fulde tidsvindue og hvorfor dette er mere end summen af enkelte faktorer.]\"
  },
  \"week_summary\": \"[skriv 3-4 sætninger jf. FELT: week_summary ovenfor]\",
  \"competitive_advantage\": \"[SÆT. A starter med 'Netop denne uge er fordelen, at …' + SÆT. B sekundær dimension — jf. FELT: competitive_advantage ovenfor]\",
  \"angles\": [
    {
