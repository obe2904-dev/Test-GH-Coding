- **${menuCapabilities.map(m => `- ${m.category}: ${m.count} items — ${m.strategic_value}`).join('\n')}`}

${context.v5_identity ? `
═══════════════════════════════════════════════
V5 BRAND IDENTITY (Layer 3 - Verified Facts)
