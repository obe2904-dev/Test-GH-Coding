# Supabase Edge Functions Environment Variables
# Copy this file to .env and fill in your values
# Then deploy with: supabase secrets set --env-file supabase/.env

# OpenAI API key for menu structuring
OPENAI_API_KEY=your-openai-api-key-here

# Docling service URL (Cloud Run endpoint)
# After deploying the docling-service, get the URL from:
# gcloud run services describe docling-menu-extractor --region us-central1 --format 'value(status.url)'
DOCLING_SERVICE_URL=https://docling-menu-extractor-xxxxx-uc.a.run.app

# Supabase service role key (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Safe rollout controls for broader menu extraction routing
MENU_EXTRACT_BROADENED_ROUTING_ENABLED=false
MENU_EXTRACT_BROADENED_ROUTING_TEST_ONLY=true
MENU_EXTRACT_BROADENED_ROUTING_BUSINESS_IDS=your-test-business-id

# Google Cloud service account for authentication (optional)
# Used if you want to authenticate Cloud Run calls
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
