# Staging Environment Variables
# Use these for Vercel preview deployments and external testing
# DO NOT commit this file with real values!

# Supabase Staging Project
VITE_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key-here

# Staging Edge Functions
VITE_SUPABASE_FUNCTION_SPELLING=https://YOUR_STAGING_REF.supabase.co/functions/v1/spelling
VITE_SUPABASE_FUNCTION_ANALYZE_WEBSITE=https://YOUR_STAGING_REF.supabase.co/functions/v1/analyze-website
VITE_SUPABASE_FUNCTION_MENU_EXTRACT=https://YOUR_STAGING_REF.supabase.co/functions/v1/menu-extract-v2
VITE_SUPABASE_FUNCTION_AI_ENHANCE=https://YOUR_STAGING_REF.supabase.co/functions/v1/ai-enhance
VITE_SUPABASE_FUNCTION_ADJUST_TEXT=https://YOUR_STAGING_REF.supabase.co/functions/v1/adjust-text

# Optional: Make.com webhooks (if using in staging)
VITE_MAKE_WEBHOOK_AI_GENERATE=https://hook.eu1.make.com/YOUR_STAGING_WEBHOOK
VITE_MAKE_WEBHOOK_PUBLISH=https://hook.eu1.make.com/YOUR_STAGING_WEBHOOK
VITE_MAKE_WEBHOOK_AI_IDEAS=https://hook.eu1.make.com/YOUR_STAGING_WEBHOOK

# OpenWeatherMap (same key as production is fine for testing)
VITE_OPENWEATHERMAP_API_KEY=your-openweathermap-key-here

# Note: OpenAI API key is set directly in Supabase Edge Functions secrets
# Not needed in frontend environment variables
